NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_publishable_or_anon_key
NEXT_PUBLIC_GROWLY_API_URL=http://localhost:8000
# Local development can bypass Auth. Production always requires Supabase Auth.
NEXT_PUBLIC_AUTH_REQUIRED=false
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server only. Never expose this value with a NEXT_PUBLIC_ prefix.
GROWLY_API_KEY=replace_with_the_same_value_as_backend_GROWLY_WEB_API_KEY
SUPABASE_SECRET_API_KEY=replace_with_supabase_service_role_key

# Polar billing. Keep these server-only.
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
POLAR_SUCCESS_URL=
POLAR_CANCEL_URL=
POLAR_STARTER_PRODUCT_ID=
POLAR_PRO_PRODUCT_ID=
POLAR_AGENCY_PRODUCT_ID=
