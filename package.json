{
  "name": "growly",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "dependencies": {
    "postcss": "8.5.15"
  },
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "start": "npm run start --workspace frontend",
    "lint": "npm run lint --workspace frontend",
    "test:web": "npm run test --workspace frontend"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
