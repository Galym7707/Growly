APP_NAME=Growly
ENVIRONMENT=development

TELEGRAM_BOT_API_KEY=replace_with_telegram_bot_token
TELEGRAM_PUBLISH_CHAT_ID=
TELEGRAM_CHANNEL_ID=

GITHUB_MODELS_TOKEN=
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
GITHUB_MODELS_MODEL=openai/gpt-5-mini

AI_PRIMARY_PROVIDER=github_models
AI_FALLBACK_PROVIDER=groq

GROQ_API_KEY=replace_with_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

SEARCH_PROVIDER=tavily
TAVILY_API_KEY=replace_with_tavily_api_key
SEARCH_MAX_RESULTS=10
SEARCH_DEPTH=basic
SEARCH_SAVE_RAW=true

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_API_KEY=replace_with_publishable_key
SUPABASE_SECRET_API_KEY=replace_with_secret_key
SUPABASE_DB_PASSWORD=replace_with_database_password
DATABASE_URL=postgresql://postgres:replace_with_password@db.your-project.supabase.co:5432/postgres?sslmode=require

NOTION_API_KEY=replace_with_notion_integration_token
NOTION_ROOT_PAGE_ID=replace_with_root_page_id

INSTAGRAM_ENABLED=false
BITRIX_ENABLED=false
ERPNEXT_ENABLED=false
CRM_PROVIDER=none

SCHEDULER_ENABLED=false
WEEKLY_REPORT_DAY=monday
WEEKLY_REPORT_HOUR=9
WEEKLY_REPORT_MINUTE=0
TIMEZONE=Asia/Almaty
