APP_NAME=Growly
ENVIRONMENT=development
DEFAULT_LANGUAGE=ru

TELEGRAM_BOT_API_KEY=replace_with_telegram_bot_token
TELEGRAM_PUBLISH_CHAT_ID=
TELEGRAM_CHANNEL_ID=

GITHUB_MODELS_TOKEN=
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
GITHUB_MODELS_MODEL=openai/gpt-5-mini

AI_PRIMARY_PROVIDER=github_models
AI_FALLBACK_PROVIDER=groq

GROQ_API_KEY=replace_with_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

SEARCH_PROVIDER=tavily
TAVILY_API_KEY=replace_with_tavily_api_key
SEARCH_MAX_RESULTS=10
SEARCH_DEPTH=basic
SEARCH_SAVE_RAW=true

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_API_KEY=replace_with_publishable_key
SUPABASE_SECRET_API_KEY=replace_with_secret_key
SUPABASE_DB_PASSWORD=replace_with_database_password
DATABASE_URL=postgresql://postgres:replace_with_password@db.your-project.supabase.co:5432/postgres?sslmode=require
RUN_DATABASE_MIGRATIONS=true

NOTION_API_KEY=replace_with_notion_integration_token
NOTION_ROOT_PAGE_ID=replace_with_root_page_id

GROWLY_WEB_API_KEY=replace_with_long_random_server_key
WEB_ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Polar billing (server-only except NEXT_PUBLIC_APP_URL) ---
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
POLAR_SUCCESS_URL=
POLAR_CANCEL_URL=
POLAR_STARTER_PRODUCT_ID=
POLAR_PRO_PRODUCT_ID=
POLAR_AGENCY_PRODUCT_ID=

# Key used to encrypt user-supplied secrets (e.g. the Blotato API key saved in
# the UI) at rest. Optional: if unset, the GROWLY_WEB_API_KEY is used to derive
# it. Set a dedicated value in production. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENCRYPTION_KEY=

# Admin access (admin-assisted manual connection MVP). Comma-separated list of
# emails allowed to use /admin/* endpoints and the /admin/integrations/blotato
# page. The email is matched against the authenticated session (injected by the
# proxy). With neither ADMIN_EMAILS nor ADMIN_SECRET set, admin access is denied.
ADMIN_EMAILS=
ADMIN_SECRET=

# --- Blotato social publishing (backend-only; never exposed to the frontend) ---
# The Growly OWNER buys Blotato and keeps ONE global key here. Regular users
# never enter or see this key — they submit a connection request and the owner
# links their Instagram account in the admin panel after an OAuth call.
# BLOTATO_ENABLED=true is the single-tenant switch for the global key.
BLOTATO_ENABLED=false
BLOTATO_API_KEY=replace_with_blotato_api_key
BLOTATO_BASE_URL=https://backend.blotato.com/v2
# Optional fallback account ids used when no workspace mapping is saved:
BLOTATO_INSTAGRAM_ACCOUNT_ID=
BLOTATO_THREADS_ACCOUNT_ID=
BLOTATO_TIKTOK_ACCOUNT_ID=
BLOTATO_YOUTUBE_ACCOUNT_ID=
BLOTATO_FACEBOOK_ACCOUNT_ID=
BLOTATO_FACEBOOK_PAGE_ID=
BLOTATO_LINKEDIN_ACCOUNT_ID=
BLOTATO_LINKEDIN_PAGE_ID=
BLOTATO_X_ACCOUNT_ID=

INSTAGRAM_ENABLED=false
BITRIX_ENABLED=false
ERPNEXT_ENABLED=false
CRM_PROVIDER=none

SCHEDULER_ENABLED=false
WEEKLY_REPORT_DAY=monday
WEEKLY_REPORT_HOUR=9
WEEKLY_REPORT_MINUTE=0
TIMEZONE=Asia/Almaty
